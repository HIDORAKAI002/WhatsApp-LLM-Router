# ==========================================
# ENTERPRISE AI WHATSAPP AGENT CONFIGURATION
# ==========================================
# Rename this file to `.env` and fill in your API keys below.
# You do NOT need all of these keys. You only need the keys for the AIs you want to use.

# ==========================================
# 1. PRIMARY AI PROVIDERS (FASTEST)
# ==========================================
# GROQ (Extremely fast LLaMA models) -> Get your free key here: https://console.groq.com/keys
# You can paste multiple keys separated by commas to enable automatic Load Balancing!
GROQ_API_KEYS=gsk_your_key_here,gsk_your_second_key_here

# MISTRAL AI -> Get your free key here: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# GOOGLE GEMINI -> Get your free key here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OPENAI (ChatGPT) -> Get your paid key here: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ANTHROPIC (Claude) -> Get your paid key here: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ==========================================
# 2. OPEN-SOURCE & FREE PROVIDERS
# ==========================================
# OpenRouter (Aggregator) -> Get key here: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Together AI -> Get key here: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Cerebras (Ultra-Fast Inference) -> Get key here: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# ==========================================
# 3. ROUTING ENGINE FAILOVER
# ==========================================
# The AI Router will attempt to use these APIs in the exact order listed here.
# If an API fails, goes offline, or runs out of credits, it will instantly failover to the next one.
AI_FALLBACK_ORDER=gemini,groq,mistral,openrouter,cerebras,openai

# ==========================================
# 4. AGENT CONNECTION SETTINGS
# ==========================================
# The URL where your Text Agent (NodeJS) is running.
# - If running locally on your computer: http://localhost:3000
# - If running on a VPS or Pterodactyl: http://YOUR_VPS_IP:3000
TEXT_AGENT_URL=http://localhost:3000
